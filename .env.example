# --- LLM provider (default: ollama) ---
LCI_LLM_PROVIDER=ollama
LCI_OLLAMA_HOST=http://localhost:11434
LCI_OLLAMA_MODEL=llama3.2:3b

# Optional: OpenAI fallback. Override with --provider openai on the CLI.
OPENAI_API_KEY=

# --- Embeddings ---
LCI_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
LCI_EMBEDDING_DEVICE=mps  # mps | cuda | cpu

# --- Qdrant ---
LCI_QDRANT_URL=http://localhost:6333
LCI_QDRANT_COLLECTION=contracts

# --- SEC EDGAR ---
# EDGAR requires a User-Agent identifying yourself per their fair-use policy.
LCI_EDGAR_USER_AGENT=Akhil Gorantala akhilgorantala1@gmail.com

# --- Langfuse (Phase 4 observability) ---
# Tracing is automatic when these three are set. Leave LANGFUSE_PUBLIC_KEY blank
# to disable instrumentation entirely.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Cost estimator (Phase 4) — used to attach a $ figure to each trace.
# Defaults reflect a rough Apple-Silicon M-series MPS run; override for cloud GPU.
LCI_COST_PER_M_INPUT_TOKENS=0.0
LCI_COST_PER_M_OUTPUT_TOKENS=0.0
LCI_COST_PER_REQUEST_OVERHEAD_USD=0.0
